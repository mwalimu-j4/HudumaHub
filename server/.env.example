# HudumaHub Server — Environment Variables

# App
NODE_ENV=development
PORT=5000

# Database (Neon PostgreSQL in production)
DATABASE_URL="postgresql://user:password@localhost:5432/hudumahub?schema=public"

# Auth
JWT_SECRET="change-this-to-a-secure-random-string"

# CORS — comma-separated origins
CORS_ORIGIN="http://localhost:5173"

# Cloud AI Provider (Groq free tier — https://console.groq.com)
# Also works with OpenAI, Together AI, OpenRouter, etc.
AI_API_KEY="gsk_your-groq-api-key-here"
AI_PROVIDER_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
AI_MAX_TOKENS=2048
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=60000
